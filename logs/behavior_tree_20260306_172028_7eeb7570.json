{
  "type": "Sequence",
  "name": "天气数据记录系统",
  "id": "weatherDataSystem",
  "children": [
    {
      "type": "Sequence",
      "name": "准备工作",
      "id": "prepareWork",
      "children": [
        {
          "type": "Action",
          "name": "创建主目录",
          "id": "actionCreateMainDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据"
          }
        },
        {
          "type": "Sequence",
          "name": "创建子目录",
          "id": "createSubDirs",
          "children": [
            {
              "type": "Action",
              "name": "创建当前天气目录",
              "id": "actionCreateCurrentWeatherDir",
              "tool": "file_operations",
              "parameters": {
                "operation": "create",
                "path": "天气数据/当前天气"
              }
            },
            {
              "type": "Action",
              "name": "创建天气预报目录",
              "id": "actionCreateWeatherForecastDir",
              "tool": "file_operations",
              "parameters": {
                "operation": "create",
                "path": "天气数据/天气预报"
              }
            },
            {
              "type": "Action",
              "name": "创建天气报告目录",
              "id": "actionCreateWeatherReportDir",
              "tool": "file_operations",
              "parameters": {
                "operation": "create",
                "path": "天气数据/天气报告"
              }
            }
          ]
        },
        {
          "type": "Action",
          "name": "创建完成信息文件",
          "id": "actionCreateCompletionInfoFile",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/完成信息.txt"
          }
        }
      ]
    },
    {
      "type": "Parallel",
      "name": "天气查询和记录",
      "id": "weatherQueryAndRecord",
      "children": [
        {
          "type": "Sequence",
          "name": "查询并记录当前天气",
          "id": "queryAndRecordCurrentWeather",
          "children": [
            {
              "type": "Action",
              "name": "查询当前天气",
              "id": "actionQueryCurrentWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "ip_weather"
              }
            },
            {
              "type": "Action",
              "name": "保存当前天气",
              "id": "actionSaveCurrentWeather",
              "tool": "file_operations",
              "parameters": {
                "operation": "write",
                "path": "天气数据/当前天气/current_weather.txt"
              }
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "查询并记录北京天气",
          "id": "queryAndRecordBeijingWeather",
          "children": [
            {
              "type": "Action",
              "name": "查询北京天气",
              "id": "actionQueryBeijingWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "北京",
                "city": "北京"
              }
            },
            {
              "type": "Action",
              "name": "保存北京天气",
              "id": "actionSaveBeijingWeather",
              "tool": "file_operations",
              "parameters": {
                "operation": "write",
                "path": "天气数据/天气预报/beijing_weather.txt"
              }
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "查询并记录上海天气",
          "id": "queryAndRecordShanghaiWeather",
          "children": [
            {
              "type": "Action",
              "name": "查询上海天气",
              "id": "actionQueryShanghaiWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "上海",
                "city": "上海"
              }
            },
            {
              "type": "Action",
              "name": "保存上海天气",
              "id": "actionSaveShanghaiWeather",
              "tool": "file_operations",
              "parameters": {
                "operation": "write",
                "path": "天气数据/天气预报/shanghai_weather.txt"
              }
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "查询并记录广州天气",
          "id": "queryAndRecordGuangzhouWeather",
          "children": [
            {
              "type": "Action",
              "name": "查询广州天气",
              "id": "actionQueryGuangzhouWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "广东",
                "city": "广州"
              }
            },
            {
              "type": "Action",
              "name": "保存广州天气",
              "id": "actionSaveGuangzhouWeather",
              "tool": "file_operations",
              "parameters": {
                "operation": "write",
                "path": "天气数据/天气预报/guangzhou_weather.txt"
              }
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "查询并记录深圳天气",
          "id": "queryAndRecordShenzhenWeather",
          "children": [
            {
              "type": "Action",
              "name": "查询深圳天气",
              "id": "actionQueryShenzhenWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "广东",
                "city": "深圳"
              }
            },
            {
              "type": "Action",
              "name": "保存深圳天气",
              "id": "actionSaveShenzhenWeather",
              "tool": "file_operations",
              "parameters": {
                "operation": "write",
                "path": "天气数据/天气预报/shenzhen_weather.txt"
              }
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "查询并记录国外天气",
          "id": "queryAndRecordForeignWeather",
          "children": [
            {
              "type": "Action",
              "name": "查询纽约天气",
              "id": "actionQueryNewYorkWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "foreign_weather",
                "city": "纽约"
              }
            },
            {
              "type": "Action",
              "name": "查询伦敦天气",
              "id": "actionQueryLondonWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "foreign_weather",
                "city": "伦敦"
              }
            },
            {
              "type": "Action",
              "name": "查询东京天气",
              "id": "actionQueryTokyoWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "foreign_weather",
                "city": "东京"
              }
            }
          ]
        },
        {
          "type": "Action",
          "name": "保存国外天气",
          "id": "actionSaveForeignWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/foreign_weather.txt"
          }
        }
      ]
    },
    {
      "type": "Sequence",
      "name": "报告生成",
      "id": "reportGeneration",
      "children": [
        {
          "type": "Action",
          "name": "生成详细天气报告",
          "id": "actionGenerateDetailedWeatherReport",
          "tool": "text_processing",
          "parameters": {
            "operation": "summarize"
          }
        },
        {
          "type": "Action",
          "name": "生成天气摘要",
          "id": "actionGenerateWeatherSummary",
          "tool": "text_processing",
          "parameters": {
            "operation": "summarize"
          }
        }
      ]
    },
    {
      "type": "Action",
      "name": "验证和清理",
      "id": "validationAndCleanup",
      "tool": "file_operations",
      "parameters": {
        "operation": "list",
        "path": "天气数据"
      }
    }
  ]
}