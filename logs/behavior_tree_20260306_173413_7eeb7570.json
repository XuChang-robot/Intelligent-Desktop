{
  "type": "Sequence",
  "name": "创建天气数据记录系统",
  "id": "sequenceCreateWeatherSystem",
  "children": [
    {
      "type": "Sequence",
      "name": "准备工作",
      "id": "sequencePrepareWork",
      "children": [
        {
          "type": "Action",
          "name": "创建主目录",
          "id": "actionCreateMainDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据"
          }
        },
        {
          "type": "Sequence",
          "name": "创建子目录",
          "id": "sequenceCreateSubDirs",
          "children": [
            {
              "type": "Action",
              "name": "创建当前天气目录",
              "id": "actionCreateCurrentWeatherDir",
              "tool": "file_operations",
              "parameters": {
                "operation": "create",
                "path": "天气数据/当前天气"
              }
            },
            {
              "type": "Action",
              "name": "创建天气预报目录",
              "id": "actionCreateForecastDir",
              "tool": "file_operations",
              "parameters": {
                "operation": "create",
                "path": "天气数据/天气预报"
              }
            },
            {
              "type": "Action",
              "name": "创建天气报告目录",
              "id": "actionCreateReportDir",
              "tool": "file_operations",
              "parameters": {
                "operation": "create",
                "path": "天气数据/天气报告"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Parallel",
      "name": "并行天气查询",
      "id": "parallelWeatherQueries",
      "children": [
        {
          "type": "Sequence",
          "name": "查询当前IP天气",
          "id": "sequenceQueryIPWeather",
          "children": [
            {
              "type": "Action",
              "name": "查询IP天气",
              "id": "actionQueryIPWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "ip_weather",
                "days": 7,
                "suntimetype": 1
              }
            },
            {
              "type": "Action",
              "name": "保存当前天气数据",
              "id": "actionSaveCurrentWeather",
              "tool": "file_operations",
              "parameters": {
                "operation": "write",
                "path": "天气数据/当前天气/current_weather.txt",
                "content": "{{queryIPWeather.result}}",
                "overwrite": true
              }
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "查询国内城市天气",
          "id": "sequenceQueryDomesticWeather",
          "children": [
            {
              "type": "Sequence",
              "name": "查询北京天气",
              "id": "sequenceQueryBeijingWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询北京天气",
                  "id": "actionQueryBeijingWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "domestic_weather",
                    "province": "北京",
                    "city": "北京",
                    "days": 5,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存北京天气数据",
                  "id": "actionSaveBeijingWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/beijing_weather.txt",
                    "content": "{{queryBeijingWeather.result}}",
                    "overwrite": true
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "查询上海天气",
              "id": "sequenceQueryShanghaiWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询上海天气",
                  "id": "actionQueryShanghaiWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "domestic_weather",
                    "province": "上海",
                    "city": "上海",
                    "days": 5,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存上海天气数据",
                  "id": "actionSaveShanghaiWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/shanghai_weather.txt",
                    "content": "{{queryShanghaiWeather.result}}",
                    "overwrite": true
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "查询广州天气",
              "id": "sequenceQueryGuangzhouWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询广州天气",
                  "id": "actionQueryGuangzhouWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "domestic_weather",
                    "province": "广东",
                    "city": "广州",
                    "days": 5,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存广州天气数据",
                  "id": "actionSaveGuangzhouWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/guangzhou_weather.txt",
                    "content": "{{queryGuangzhouWeather.result}}",
                    "overwrite": true
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "查询深圳天气",
              "id": "sequenceQueryShenzhenWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询深圳天气",
                  "id": "actionQueryShenzhenWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "domestic_weather",
                    "province": "广东",
                    "city": "深圳",
                    "days": 5,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存深圳天气数据",
                  "id": "actionSaveShenzhenWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/shenzhen_weather.txt",
                    "content": "{{queryShenzhenWeather.result}}",
                    "overwrite": true
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "查询国外城市天气",
              "id": "sequenceQueryForeignWeather",
              "children": [
                {
                  "type": "Sequence",
                  "name": "查询纽约天气",
                  "id": "sequenceQueryNewYorkWeather",
                  "children": [
                    {
                      "type": "Action",
                      "name": "查询纽约天气",
                      "id": "actionQueryNewYorkWeather",
                      "tool": "weather_query",
                      "parameters": {
                        "operation": "foreign_weather",
                        "city": "纽约",
                        "days": 6,
                        "suntimetype": 1
                      }
                    },
                    {
                      "type": "Action",
                      "name": "保存纽约天气数据",
                      "id": "actionSaveNewYorkWeather",
                      "tool": "file_operations",
                      "parameters": {
                        "operation": "write",
                        "path": "天气数据/天气预报/foreign_weather.txt",
                        "content": "{{queryNewYorkWeather.result}}",
                        "overwrite": true
                      }
                    }
                  ]
                },
                {
                  "type": "Sequence",
                  "name": "查询伦敦天气",
                  "id": "sequenceQueryLondonWeather",
                  "children": [
                    {
                      "type": "Action",
                      "name": "查询伦敦天气",
                      "id": "actionQueryLondonWeather",
                      "tool": "weather_query",
                      "parameters": {
                        "operation": "foreign_weather",
                        "city": "伦敦",
                        "days": 6,
                        "suntimetype": 1
                      }
                    },
                    {
                      "type": "Action",
                      "name": "保存伦敦天气数据",
                      "id": "actionSaveLondonWeather",
                      "tool": "file_operations",
                      "parameters": {
                        "operation": "write",
                        "path": "天气数据/天气预报/foreign_weather.txt",
                        "content": "{{queryLondonWeather.result}}",
                        "overwrite": true
                      }
                    }
                  ]
                },
                {
                  "type": "Sequence",
                  "name": "查询东京天气",
                  "id": "sequenceQueryTokyoWeather",
                  "children": [
                    {
                      "type": "Action",
                      "name": "查询东京天气",
                      "id": "actionQueryTokyoWeather",
                      "tool": "weather_query",
                      "parameters": {
                        "operation": "foreign_weather",
                        "city": "东京",
                        "days": 6,
                        "suntimetype": 1
                      }
                    },
                    {
                      "type": "Action",
                      "name": "保存东京天气数据",
                      "id": "actionSaveTokyoWeather",
                      "tool": "file_operations",
                      "parameters": {
                        "operation": "write",
                        "path": "天气数据/天气预报/foreign_weather.txt",
                        "content": "{{queryTokyoWeather.result}}",
                        "overwrite": true
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "生成天气报告",
              "id": "sequenceGenerateReport",
              "children": [
                {
                  "type": "Action",
                  "name": "生成天气报告",
                  "id": "actionGenerateReport",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气报告/weather_report.txt",
                    "content": "{{queryIPWeather.result}}, {{queryBeijingWeather.result}}, {{queryShanghaiWeather.result}}, {{queryGuangzhouWeather.result}}, {{queryShenzhenWeather.result}}, {{queryNewYorkWeather.result}}, {{queryLondonWeather.result}}, {{queryTokyoWeather.result}}",
                    "overwrite": true
                  }
                },
                {
                  "type": "Action",
                  "name": "生成天气摘要",
                  "id": "actionGenerateSummary",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气报告/weather_summary.txt",
                    "content": "当前天气: {{queryIPWeather.result}}, 北京: {{queryBeijingWeather.result}}, 上海: {{queryShanghaiWeather.result}}, 广州: {{queryGuangzhouWeather.result}}, 深圳: {{queryShenzhenWeather.result}}, 纽约: {{queryNewYorkWeather.result}}, 伦敦: {{queryLondonWeather.result}}, 东京: {{queryTokyoWeather.result}}",
                    "overwrite": true
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "验证和清理",
              "id": "sequenceVerifyAndClean",
              "children": [
                {
                  "type": "Action",
                  "name": "验证文件创建",
                  "id": "actionVerifyFiles",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "read",
                    "path": "天气数据/当前天气/current_weather.txt"
                  }
                },
                {
                  "type": "Action",
                  "name": "生成完成报告",
                  "id": "actionGenerateCompletionReport",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/完成信息.txt",
                    "content": "天气数据记录系统创建完成",
                    "overwrite": true
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}