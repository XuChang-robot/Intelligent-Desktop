{
  "type": "Sequence",
  "name": "创建天气数据记录系统",
  "id": "sequenceCreateWeatherSystem",
  "children": [
    {
      "type": "Sequence",
      "name": "准备工作",
      "id": "sequencePrepareWork",
      "children": [
        {
          "type": "Action",
          "name": "创建主目录",
          "id": "actionCreateMainDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据"
          }
        },
        {
          "type": "Action",
          "name": "创建当前天气目录",
          "id": "actionCreateCurrentWeatherDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/当前天气"
          }
        },
        {
          "type": "Action",
          "name": "创建天气预报目录",
          "id": "actionCreateForecastDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/天气预报"
          }
        },
        {
          "type": "Action",
          "name": "创建天气报告目录",
          "id": "actionCreateReportDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/天气报告"
          }
        }
      ]
    },
    {
      "type": "Parallel",
      "name": "天气查询并记录",
      "id": "parallelQueryWeather",
      "children": [
        {
          "type": "Action",
          "name": "查询当前IP天气",
          "id": "actionQueryCurrentWeather",
          "tool": "weather_query",
          "parameters": {
            "operation": "ip_weather"
          }
        },
        {
          "type": "Sequence",
          "name": "国内城市天气查询",
          "id": "sequenceQueryDomesticCities",
          "children": [
            {
              "type": "Action",
              "name": "查询北京天气",
              "id": "actionQueryBeijingWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "北京",
                "city": "北京市"
              }
            },
            {
              "type": "Action",
              "name": "查询上海天气",
              "id": "actionQueryShanghaiWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "上海",
                "city": "上海市"
              }
            },
            {
              "type": "Action",
              "name": "查询广州天气",
              "id": "actionQueryGuangzhouWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "广东",
                "city": "广州市"
              }
            },
            {
              "type": "Action",
              "name": "查询深圳天气",
              "id": "actionQueryShenzhenWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "广东",
                "city": "深圳市"
              }
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "国外城市天气查询",
          "id": "sequenceQueryForeignCities",
          "children": [
            {
              "type": "Action",
              "name": "查询纽约天气",
              "id": "actionQueryNewYorkWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "foreign_weather",
                "city": "纽约"
              }
            },
            {
              "type": "Action",
              "name": "查询伦敦天气",
              "id": "actionQueryLondonWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "foreign_weather",
                "city": "伦敦"
              }
            },
            {
              "type": "Action",
              "name": "查询东京天气",
              "id": "actionQueryTokyoWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "foreign_weather",
                "city": "东京"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Sequence",
      "name": "保存天气数据",
      "id": "sequenceSaveWeatherData",
      "children": [
        {
          "type": "Action",
          "name": "保存当前天气",
          "id": "actionSaveCurrentWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/当前天气/current_weather.txt",
            "content": "{{actionQueryCurrentWeather.result}}"
          }
        },
        {
          "type": "Action",
          "name": "保存北京天气",
          "id": "actionSaveBeijingWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/beijing_weather.txt",
            "content": "{{actionQueryBeijingWeather.result}}"
          }
        },
        {
          "type": "Action",
          "name": "保存上海天气",
          "id": "actionSaveShanghaiWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/shanghai_weather.txt",
            "content": "{{actionQueryShanghaiWeather.result}}"
          }
        },
        {
          "type": "Action",
          "name": "保存广州天气",
          "id": "actionSaveGuangzhouWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/guangzhou_weather.txt",
            "content": "{{actionQueryGuangzhouWeather.result}}"
          }
        },
        {
          "type": "Action",
          "name": "保存深圳天气",
          "id": "actionSaveShenzhenWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/shenzhen_weather.txt",
            "content": "{{actionQueryShenzhenWeather.result}}"
          }
        },
        {
          "type": "Action",
          "name": "保存国外城市天气",
          "id": "actionSaveForeignWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/foreign_weather.txt",
            "content": "{{actionQueryNewYorkWeather.result}} {{actionQueryLondonWeather.result}} {{actionQueryTokyoWeather.result}}"
          }
        }
      ]
    },
    {
      "type": "Sequence",
      "name": "报告生成",
      "id": "sequenceGenerateReport",
      "children": [
        {
          "type": "Action",
          "name": "生成天气报告",
          "id": "actionGenerateWeatherReport",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气报告/weather_report.txt",
            "content": "所有城市天气信息汇总"
          }
        },
        {
          "type": "Action",
          "name": "生成天气摘要",
          "id": "actionGenerateWeatherSummary",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气报告/weather_summary.txt",
            "content": "天气摘要信息"
          }
        }
      ]
    },
    {
      "type": "Sequence",
      "name": "验证和清理",
      "id": "sequenceValidateAndClean",
      "children": [
        {
          "type": "Action",
          "name": "验证文件创建",
          "id": "actionValidateFiles",
          "tool": "file_operations",
          "parameters": {
            "operation": "list",
            "path": "天气数据"
          }
        },
        {
          "type": "Action",
          "name": "生成任务完成报告",
          "id": "actionGenerateCompletionReport",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/完成信息.txt",
            "content": "天气数据记录系统已成功创建"
          }
        }
      ]
    }
  ]
}