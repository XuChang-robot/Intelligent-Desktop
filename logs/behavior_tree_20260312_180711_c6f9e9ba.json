{
  "type": "Sequence",
  "name": "创建天气数据记录系统",
  "id": "sequenceCreateWeatherSystem",
  "children": [
    {
      "type": "Sequence",
      "name": "准备工作",
      "id": "sequencePrepareWork",
      "children": [
        {
          "type": "Action",
          "name": "创建主目录",
          "id": "actionCreateMainDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "创建当前天气目录",
          "id": "actionCreateCurrentWeatherDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/当前天气"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "创建天气预报目录",
          "id": "actionCreateForecastDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/天气预报"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        }
      ]
    },
    {
      "type": "Parallel",
      "name": "天气查询并记录",
      "id": "parallelQueryWeather",
      "children": [
        {
          "type": "Action",
          "name": "查询当前IP天气",
          "id": "actionQueryCurrentWeather",
          "tool": "weather_query",
          "parameters": {
            "operation": "ip_weather",
            "days": 7,
            "suntimetype": 1
          },
          "intelligence_config": {
            "enabled": true,
            "strategy": "infer",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Sequence",
          "name": "查询国内城市天气",
          "id": "sequenceQueryDomesticCities",
          "children": [
            {
              "type": "Action",
              "name": "查询北京天气",
              "id": "actionQueryBeijingWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "北京",
                "city": "北京市",
                "days": 5
              },
              "intelligence_config": {
                "enabled": true,
                "strategy": "infer",
                "auto_execute_threshold": 0.85,
                "confirm_threshold": 0.6
              }
            },
            {
              "type": "Action",
              "name": "查询上海天气",
              "id": "actionQueryShanghaiWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "上海",
                "city": "上海市",
                "days": 5
              },
              "intelligence_config": {
                "enabled": true,
                "strategy": "infer",
                "auto_execute_threshold": 0.85,
                "confirm_threshold": 0.6
              }
            },
            {
              "type": "Action",
              "name": "查询广州天气",
              "id": "actionQueryGuangzhouWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "广东",
                "city": "广州市",
                "days": 5
              },
              "intelligence_config": {
                "enabled": true,
                "strategy": "infer",
                "auto_execute_threshold": 0.85,
                "confirm_threshold": 0.6
              }
            },
            {
              "type": "Action",
              "name": "查询深圳天气",
              "id": "actionQueryShenzhenWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "domestic_weather",
                "province": "广东",
                "city": "深圳市",
                "days": 5
              },
              "intelligence_config": {
                "enabled": true,
                "strategy": "infer",
                "auto_execute_threshold": 0.85,
                "confirm_threshold": 0.6
              }
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "查询国外城市天气",
          "id": "sequenceQueryForeignCities",
          "children": [
            {
              "type": "Action",
              "name": "查询纽约天气",
              "id": "actionQueryNewYorkWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "foreign_weather",
                "city": "纽约",
                "days": 6
              },
              "intelligence_config": {
                "enabled": true,
                "strategy": "infer",
                "auto_execute_threshold": 0.85,
                "confirm_threshold": 0.6
              }
            },
            {
              "type": "Action",
              "name": "查询伦敦天气",
              "id": "actionQueryLondonWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "foreign_weather",
                "city": "伦敦",
                "days": 6
              },
              "intelligence_config": {
                "enabled": true,
                "strategy": "infer",
                "auto_execute_threshold": 0.85,
                "confirm_threshold": 0.6
              }
            },
            {
              "type": "Action",
              "name": "查询东京天气",
              "id": "actionQueryTokyoWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "foreign_weather",
                "city": "东京",
                "days": 6
              },
              "intelligence_config": {
                "enabled": true,
                "strategy": "infer",
                "auto_execute_threshold": 0.85,
                "confirm_threshold": 0.6
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Sequence",
      "name": "报告生成",
      "id": "sequenceGenerateReports",
      "children": [
        {
          "type": "Action",
          "name": "保存当前天气数据",
          "id": "actionSaveCurrentWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/当前天气/current_weather.txt",
            "content": "{{actionQueryCurrentWeather.result}}"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "保存北京天气数据",
          "id": "actionSaveBeijingWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/beijing_weather.txt",
            "content": "{{actionQueryBeijingWeather.result}}"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "保存上海天气数据",
          "id": "actionSaveShanghaiWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/shanghai_weather.txt",
            "content": "{{actionQueryShanghaiWeather.result}}"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "保存广州天气数据",
          "id": "actionSaveGuangzhouWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/guangzhou_weather.txt",
            "content": "{{actionQueryGuangzhouWeather.result}}"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "保存深圳天气数据",
          "id": "actionSaveShenzhenWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/shenzhen_weather.txt",
            "content": "{{actionQueryShenzhenWeather.result}}"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "保存国外城市天气数据",
          "id": "actionSaveForeignWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/foreign_weather.txt",
            "content": "{{actionQueryNewYorkWeather.result}} {{actionQueryLondonWeather.result}} {{actionQueryTokyoWeather.result}}"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "生成天气报告",
          "id": "actionGenerateWeatherReport",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气报告/weather_report.txt",
            "content": "所有城市天气数据汇总"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "生成天气摘要",
          "id": "actionGenerateWeatherSummary",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气报告/weather_summary.txt",
            "content": "天气摘要内容"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        }
      ]
    },
    {
      "type": "Sequence",
      "name": "验证和清理",
      "id": "sequenceVerifyAndClean",
      "children": [
        {
          "type": "Action",
          "name": "验证文件创建",
          "id": "actionVerifyFiles",
          "tool": "file_operations",
          "parameters": {
            "operation": "list",
            "path": "天气数据"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        },
        {
          "type": "Action",
          "name": "生成任务完成报告",
          "id": "actionGenerateCompletionReport",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/完成信息.txt",
            "content": "天气数据记录系统已成功创建"
          },
          "intelligence_config": {
            "enabled": false,
            "strategy": "direct",
            "auto_execute_threshold": 0.85,
            "confirm_threshold": 0.6
          }
        }
      ]
    }
  ]
}