{
  "type": "Sequence",
  "name": "创建天气数据记录系统",
  "id": "sequenceCreateWeatherSystem",
  "children": [
    {
      "type": "Sequence",
      "name": "准备工作",
      "id": "sequencePrepareWork",
      "children": [
        {
          "type": "Action",
          "name": "创建主目录",
          "id": "actionCreateMainDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据"
          }
        },
        {
          "type": "Action",
          "name": "创建当前天气目录",
          "id": "actionCreateCurrentWeatherDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/当前天气"
          }
        },
        {
          "type": "Action",
          "name": "创建天气预报目录",
          "id": "actionCreateForecastDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/天气预报"
          }
        },
        {
          "type": "Action",
          "name": "创建天气报告目录",
          "id": "actionCreateReportDir",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/天气报告"
          }
        }
      ]
    },
    {
      "type": "Parallel",
      "name": "并行天气查询",
      "id": "parallelQueryWeather",
      "children": [
        {
          "type": "Sequence",
          "name": "查询当前IP天气",
          "id": "sequenceQueryIPWeather",
          "children": [
            {
              "type": "Action",
              "name": "查询IP天气",
              "id": "actionQueryIPWeather",
              "tool": "weather_query",
              "parameters": {
                "operation": "ip_weather",
                "days": 7,
                "suntimetype": 1
              }
            },
            {
              "type": "Action",
              "name": "保存IP天气数据",
              "id": "actionSaveIPWeather",
              "tool": "file_operations",
              "parameters": {
                "operation": "write",
                "path": "天气数据/当前天气/current_weather.txt",
                "content": "{{actionQueryIPWeather.result.formatted_message}}"
              }
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "查询国内城市天气",
          "id": "sequenceQueryDomesticWeather",
          "children": [
            {
              "type": "Sequence",
              "name": "查询北京天气",
              "id": "sequenceQueryBeijingWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询北京天气",
                  "id": "actionQueryBeijingWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "domestic_weather",
                    "province": "北京",
                    "city": "北京",
                    "days": 5,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存北京天气数据",
                  "id": "actionSaveBeijingWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/beijing_weather.txt",
                    "content": "{{actionQueryBeijingWeather.result.formatted_message}}"
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "查询上海天气",
              "id": "sequenceQueryShanghaiWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询上海天气",
                  "id": "actionQueryShanghaiWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "domestic_weather",
                    "province": "上海",
                    "city": "上海",
                    "days": 5,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存上海天气数据",
                  "id": "actionSaveShanghaiWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/shanghai_weather.txt",
                    "content": "{{actionQueryShanghaiWeather.result.formatted_message}}"
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "查询广州天气",
              "id": "sequenceQueryGuangzhouWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询广州天气",
                  "id": "actionQueryGuangzhouWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "domestic_weather",
                    "province": "广东",
                    "city": "广州",
                    "days": 5,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存广州天气数据",
                  "id": "actionSaveGuangzhouWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/guangzhou_weather.txt",
                    "content": "{{actionQueryGuangzhouWeather.result.formatted_message}}"
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "查询深圳天气",
              "id": "sequenceQueryShenzhenWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询深圳天气",
                  "id": "actionQueryShenzhenWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "domestic_weather",
                    "province": "广东",
                    "city": "深圳",
                    "days": 5,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存深圳天气数据",
                  "id": "actionSaveShenzhenWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/shenzhen_weather.txt",
                    "content": "{{actionQueryShenzhenWeather.result.formatted_message}}"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "Sequence",
          "name": "查询国外城市天气",
          "id": "sequenceQueryForeignWeather",
          "children": [
            {
              "type": "Sequence",
              "name": "查询纽约天气",
              "id": "sequenceQueryNewYorkWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询纽约天气",
                  "id": "actionQueryNewYorkWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "foreign_weather",
                    "city": "纽约",
                    "days": 6,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存纽约天气数据",
                  "id": "actionSaveNewYorkWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/foreign_weather.txt",
                    "content": "{{actionQueryNewYorkWeather.result.formatted_message}}"
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "查询伦敦天气",
              "id": "sequenceQueryLondonWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询伦敦天气",
                  "id": "actionQueryLondonWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "foreign_weather",
                    "city": "伦敦",
                    "days": 6,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存伦敦天气数据",
                  "id": "actionSaveLondonWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/foreign_weather.txt",
                    "content": "{{actionQueryLondonWeather.result.formatted_message}}"
                  }
                }
              ]
            },
            {
              "type": "Sequence",
              "name": "查询东京天气",
              "id": "sequenceQueryTokyoWeather",
              "children": [
                {
                  "type": "Action",
                  "name": "查询东京天气",
                  "id": "actionQueryTokyoWeather",
                  "tool": "weather_query",
                  "parameters": {
                    "operation": "foreign_weather",
                    "city": "东京",
                    "days": 6,
                    "suntimetype": 1
                  }
                },
                {
                  "type": "Action",
                  "name": "保存东京天气数据",
                  "id": "actionSaveTokyoWeather",
                  "tool": "file_operations",
                  "parameters": {
                    "operation": "write",
                    "path": "天气数据/天气预报/foreign_weather.txt",
                    "content": "{{actionQueryTokyoWeather.result.formatted_message}}"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Sequence",
      "name": "数据记录",
      "id": "sequenceDataRecord",
      "children": [
        {
          "type": "Action",
          "name": "保存IP天气数据",
          "id": "actionSaveIPWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/当前天气/current_weather.txt",
            "content": "{{actionQueryIPWeather.result.formatted_message}}"
          }
        },
        {
          "type": "Action",
          "name": "保存北京天气数据",
          "id": "actionSaveBeijingWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/beijing_weather.txt",
            "content": "{{actionQueryBeijingWeather.result.formatted_message}}"
          }
        },
        {
          "type": "Action",
          "name": "保存上海天气数据",
          "id": "actionSaveShanghaiWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/shanghai_weather.txt",
            "content": "{{actionQueryShanghaiWeather.result.formatted_message}}"
          }
        },
        {
          "type": "Action",
          "name": "保存广州天气数据",
          "id": "actionSaveGuangzhouWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/guangzhou_weather.txt",
            "content": "{{actionQueryGuangzhouWeather.result.formatted_message}}"
          }
        },
        {
          "type": "Action",
          "name": "保存深圳天气数据",
          "id": "actionSaveShenzhenWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/shenzhen_weather.txt",
            "content": "{{actionQueryShenzhenWeather.result.formatted_message}}"
          }
        },
        {
          "type": "Action",
          "name": "保存国外城市天气数据",
          "id": "actionSaveForeignWeather",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气预报/foreign_weather.txt",
            "content": "{{actionQueryNewYorkWeather.result.formatted_message}}, {{actionQueryLondonWeather.result.formatted_message}}, {{actionQueryTokyoWeather.result.formatted_message}}"
          }
        }
      ]
    },
    {
      "type": "Sequence",
      "name": "报告生成",
      "id": "sequenceGenerateReport",
      "children": [
        {
          "type": "Action",
          "name": "生成详细天气报告",
          "id": "actionGenerateDetailedReport",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气报告/weather_report.txt",
            "content": "{{actionQueryIPWeather.result.formatted_message}}, {{actionQueryBeijingWeather.result.formatted_message}}, {{actionQueryShanghaiWeather.result.formatted_message}}, {{actionQueryGuangzhouWeather.result.formatted_message}}, {{actionQueryShenzhenWeather.result.formatted_message}}, {{actionQueryNewYorkWeather.result.formatted_message}}, {{actionQueryLondonWeather.result.formatted_message}}, {{actionQueryTokyoWeather.result.formatted_message}}"
          }
        },
        {
          "type": "Action",
          "name": "生成简洁天气摘要",
          "id": "actionGenerateSummaryReport",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/天气报告/weather_summary.txt",
            "content": "{{actionQueryIPWeather.result.formatted_message}}, {{actionQueryBeijingWeather.result.formatted_message}}, {{actionQueryShanghaiWeather.result.formatted_message}}, {{actionQueryGuangzhouWeather.result.formatted_message}}, {{actionQueryShenzhenWeather.result.formatted, actionQueryNewYorkWeather.result.formatted_message}}, {{actionQueryLondonWeather.result.formatted_message}}, {{actionQueryTokyoWeather.result.formatted_message}}"
          }
        }
      ]
    },
    {
      "type": "Sequence",
      "name": "验证和清理",
      "id": "sequenceVerifyAndClean",
      "children": [
        {
          "type": "Action",
          "name": "验证文件创建",
          "id": "actionVerifyFiles",
          "tool": "file_operations",
          "parameters": {
            "operation": "create",
            "path": "天气数据/当前天气/current_weather.txt"
          }
        },
        {
          "type": "Action",
          "name": "生成任务完成报告",
          "id": "actionGenerateCompletionReport",
          "tool": "file_operations",
          "parameters": {
            "operation": "write",
            "path": "天气数据/完成信息.txt",
            "content": "天气数据记录系统创建完成"
          }
        }
      ]
    }
  ]
}