{-} 天气数据记录系统
    {-} 准备工作
        --> 创建主目录
        --> 创建当前天气目录
        --> 创建天气预报目录
        --> 创建天气报告目录
    /_/ 天气查询
        {-} 查询当前IP天气
            --> 查询IP天气
            --> 保存IP天气数据
        {-} 查询国内城市天气
            {-} 查询北京天气
                --> 查询北京天气
                --> 保存北京天气数据
            {-} 查询上海天气
                --> 查询上海天气
                --> 保存上海天气数据
            {-} 查询广州天气
                --> 查询广州天气
                --> 保存广州天气数据
            {-} 查询深圳天气
                --> 查询深圳天气
                --> 保存深圳天气数据
        {-} 查询国外城市天气
            {-} 查询纽约天气
                --> 查询纽约天气
                --> 保存纽约天气数据
            {-} 查询伦敦天气
                --> 查询伦敦天气
                --> 保存伦敦天气数据
            {-} 查询东京天气
                --> 查询东京天气
                --> 保存东京天气数据
    {-} 数据记录
        --> 保存IP天气数据
        --> 保存北京天气数据
        --> 保存上海天气数据
        --> 保存广州天气数据
        --> 保存深圳天气数据
        --> 保存国外城市天气数据
    {-} 报告生成
        --> 生成详细天气报告
        --> 生成简洁天气摘要
